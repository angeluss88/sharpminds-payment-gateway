# Example client certificates for mTLS testing can be downloaded from:
# https://badssl.com/download/

# API endpoint used for integration testing.
PAYMENT_API_URL=https://client.badssl.com/

# Shared secret used to generate X-Signature (HMAC SHA-256).
PAYMENT_HMAC_SECRET=your-secret-key

# Client certificate for mTLS.
# Can be either:
# - a certificate-only PEM (then set PAYMENT_CLIENT_KEY), or
# - a combined PEM containing certificate + private key (then leave PAYMENT_CLIENT_KEY empty).
PAYMENT_CLIENT_CERT=./certs/client-cert.pem

# Optional private key path for separate cert/key setup.
# Leave empty when PAYMENT_CLIENT_CERT points to a combined PEM.
PAYMENT_CLIENT_KEY=./certs/client-key.pem

# Passphrase for encrypted private key material (separate key or combined PEM).
# Leave empty if not encrypted.
PAYMENT_CLIENT_KEY_PASSPHRASE=badssl.com

# Enable server certificate validation (true/false).
PAYMENT_VERIFY_TLS=true

# Optional request timeout in seconds.
PAYMENT_TIMEOUT=10