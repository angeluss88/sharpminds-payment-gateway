{
    "name": "mrudchenko/payment-mtls-client",
    "description": "PHP client for mTLS-secured API with HMAC signing",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Mrudchenko\\PaymentMtlsClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mrudchenko\\PaymentMtlsClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Maksym Rudchenko",
            "email": "maksym.rudchenko@gmail.com"
        }
    ],
    "keywords": [
        "php",
        "mtls",
        "hmac",
        "client"
    ]
}